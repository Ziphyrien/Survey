{
  "name": "survey",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:survey",
    "dev:survey": "cd apps/survey && bun run dev",
    "build": "bun run --filter './apps/*' build",
    "build:survey": "cd apps/survey && bun run build",
    "preview:survey": "cd apps/survey && bun run preview",
    "check": "bun run --filter './apps/*' check",
    "check:survey": "cd apps/survey && bun run check"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.16",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun"
}
